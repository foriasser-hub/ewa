# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored and never committed.

# Resend (https://resend.com) — used to send the contact form emails.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address used in "From:". Must be a verified domain in Resend,
# OR you can keep "onboarding@resend.dev" while testing.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Recipient — where the contact form messages should be delivered.
CONTACT_TO_EMAIL=contact@akademia-ia.mg

# Public site URL (used in metadataBase and absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
